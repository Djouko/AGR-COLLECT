# ================================================
# AGR-Collect Central - Configuration
# ================================================
# Copiez ce fichier vers .env et modifiez les valeurs
# cp .env.sample .env

# Domaine du serveur (IMPORTANT: changez pour votre domaine VPS)
# En local: localhost
# En production: agr-collect.votredomaine.com
DOMAIN=localhost

# Email administrateur système
SYSADMIN_EMAIL=admin@agr-collect.local

# Type SSL:
# - "selfsign" pour développement local
# - "letsencrypt" pour production (certificat automatique)
# - "customssl" pour certificat personnalisé
SSL_TYPE=selfsign

# Compte administrateur (créé automatiquement au premier démarrage)
ADMIN_EMAIL=admin@agr-collect.local
ADMIN_PASSWORD=agrcollect2025

# Ports (généralement 80 et 443)
HTTP_PORT=80
HTTPS_PORT=443

# ============================================
# CONFIGURATION EMAIL SMTP
# ============================================
# Pour Gmail:
# 1. Activez l'authentification à 2 facteurs
# 2. Google Account → Sécurité → Mots de passe des applications
# 3. Créez un mot de passe pour "Autre" → "AGR-Collect"
EMAIL_FROM=votre-email@gmail.com
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_IGNORE_TLS=false
EMAIL_USER=votre-email@gmail.com
EMAIL_PASSWORD=votre-mot-de-passe-application

# ============================================
# DÉPLOIEMENT VPS - Instructions
# ============================================
# 1. Installez Docker et Docker Compose sur le VPS
# 2. Clonez le repository: git clone <url> && cd central
# 3. Copiez .env.sample vers .env et configurez: cp .env.sample .env
# 4. Changez DOMAIN vers votre domaine réel
# 5. Changez SSL_TYPE=letsencrypt (pour certificat SSL automatique)
# 6. Lancez: docker compose build && docker compose up -d
# 7. L'admin est créé automatiquement avec ADMIN_EMAIL/ADMIN_PASSWORD ci-dessus
# 8. Accédez à https://votre-domaine.com
